<%- include('../layouts/header') %>

<div class="admin-layout">
  <%- include('../layouts/sidebar') %>
  
  <main class="main-content">
    <div class="card" style="max-width: 700px; margin: 0 auto;">
      <div class="card-header d-flex justify-between align-center">
        <h2 class="card-title">My Profile</h2>
        <a href="/profile/edit" class="btn btn-primary btn-sm">Edit Profile</a>
      </div>
      <div class="card-body">
        <div style="text-align: center; margin-bottom: 2rem;">
          <% if (admin.profileImage) { %>
            <img src="<%= admin.profileImage %>" alt="<%= admin.name %>" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 4px solid var(--color-primary);">
          <% } else { %>
            <div style="width: 120px; height: 120px; border-radius: 50%; background-color: var(--color-primary); color: var(--color-white); display: inline-flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: 700;">
              <%= admin.name.charAt(0).toUpperCase() %>
            </div>
          <% } %>
        </div>
        
        <div class="table-responsive">
          <table class="table">
            <tbody>
              <tr>
                <td style="font-weight: 600; width: 200px;">Name</td>
                <td><%= admin.name %></td>
              </tr>
              <tr>
                <td style="font-weight: 600;">Email</td>
                <td><%= admin.email %></td>
              </tr>
              <tr>
                <td style="font-weight: 600;">Role</td>
                <td><span class="badge badge-info">Administrator</span></td>
              </tr>
              <tr>
                <td style="font-weight: 600;">Member Since</td>
                <td><%= new Date(admin.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div class="d-flex gap-2 mt-3">
          <a href="/profile/edit" class="btn btn-primary">Edit Profile</a>
          <a href="/profile/change-password" class="btn btn-secondary">Change Password</a>
        </div>
      </div>
    </div>
  </main>
</div>

<%- include('../layouts/footer') %>
