<%- include('../layouts/header') %>

<div class="auth-layout">
  <div class="auth-card">
    <div class="auth-header">
      <h1 class="auth-title">Verify OTP</h1>
      <p class="auth-subtitle">Enter the 6-digit code sent to <%= email %></p>
    </div>
    
    <form action="/auth/verify-otp" method="POST">
      <div class="form-group">
        <label for="otp" class="form-label">OTP Code</label>
        <input 
          type="text" 
          id="otp" 
          name="otp" 
          class="form-control" 
          placeholder="000000"
          maxlength="6"
          pattern="[0-9]{6}"
          required
          style="text-align: center; font-size: 1.5rem; letter-spacing: 0.5rem;"
        >
        <small class="form-text">OTP expires in 5 minutes</small>
      </div>
      
      <button type="submit" class="btn btn-primary btn-block btn-lg">
        Verify OTP
      </button>
    </form>
    
    <div class="auth-footer">
      <a href="/auth/forgot-password" class="auth-link">Resend OTP</a>
    </div>
  </div>
</div>

<%- include('../layouts/footer') %>
