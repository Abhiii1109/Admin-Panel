<%- include('../layouts/header') %>

<div class="admin-layout">
  <%- include('../layouts/sidebar') %>
  
  <main class="main-content">
    <div class="card">
      <div class="card-header d-flex justify-between align-center">
        <h2 class="card-title">All Categories</h2>
        <a href="/category/create" class="btn btn-primary">
          <span>➕</span>
          <span>Add Category</span>
        </a>
      </div>
      <div class="card-body">
        <% if (categories.length > 0) { %>
          <div class="table-responsive">
            <table class="table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Status</th>
                  <th>Created At</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% categories.forEach((category, index) => { %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td><%= category.name %></td>
                    <td>
                      <span class="badge <%= category.status === 'Active' ? 'badge-success' : 'badge-danger' %>">
                        <%= category.status %>
                      </span>
                    </td>
                    <td><%= new Date(category.createdAt).toLocaleDateString() %></td>
                    <td>
                      <div class="d-flex gap-1">
                        <a href="/category/edit/<%= category._id %>" class="btn btn-sm btn-secondary">Edit</a>
                        <form action="/category/delete/<%= category._id %>" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this category?')">
                          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p style="text-align: center; color: var(--color-gray-500); padding: 2rem;">
            No categories found. <a href="/category/create" class="auth-link">Create your first category</a>
          </p>
        <% } %>
      </div>
    </div>
  </main>
</div>

<%- include('../layouts/footer') %>
